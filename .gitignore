# Life Systems data (private)
life-systems/finance/*.csv
life-systems/health/*.csv
life-systems/tasks/*.csv

# LoRA training output (large model files)
creative-studio/16bitfit-battle-mode/lora-output/

# Autoresearch intermediate frame extractions (regenerable from source video)
creative-studio/16bitfit-battle-mode/autoresearch/references/walk_cycle/frames_all/

# Portfolio & Hubs project (has its own git repo)
sw-portfolio-and-hubs-designs/

# The Block resume info (private — historical employer materials)
vault/30_domains/product-management/the-block-resume-info/

# Autonomous agent runtime artifacts — per CHANGELOG.md v3.15.0 follow-up.
# These are written continuously by launchd-scheduled agents on the Mac Mini
# (vault-indexer, vault-synthesizer, knowledge-lint, meta-agent, daily-driver,
# session-end flush). Tracking them caused merge conflicts between the
# shell-level vault auto-commit hook and Obsidian-git plugin.
vault/90_system/agent-logs/*.csv
vault/90_system/agent-logs/*.log
vault/.vault-index.db
vault/.indexer-state.json
vault/.job-feed.db
vault/.job-feed.db.lock
vault/knowledge/.lock
.claude/scheduled_tasks.lock
vault/health/.gemini-ledger.lock
vault/conflict-files-obsidian-git.md
agents-sdk/logs/*.log

# LLM Council spend tracking — private cost data
vault/health/council-spend-*.json

# Local TTS — model weights and generated audio
agents-sdk/models/**/*.onnx
agents-sdk/models/**/*.bin
vault/90_system/audio/*.mp3
!vault/90_system/audio/.gitkeep

# superpowers:brainstorming runtime state — per-session local web server
# (server.pid, server.log, events, server-stopped) plus regenerable HTML
# scaffolding. Actual brainstorm outputs land in the vault, not here.
.superpowers/
