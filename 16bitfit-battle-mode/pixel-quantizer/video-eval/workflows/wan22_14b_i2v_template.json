    "98": {
      "class_type": "WanImageToVideo",
      "inputs": {
        "width": 640,
        "height": 640,
        "length": 81,
        "batch_size": 1,
        "positive": ["93", 0],
        "negative": ["89", 0],
        "vae": ["90", 0],
        "start_image": ["97", 0]
      },
      "_meta": { "title": "WanImageToVideo" }
    },
    "101": {
      "class_type": "LoraLoaderModelOnly",
