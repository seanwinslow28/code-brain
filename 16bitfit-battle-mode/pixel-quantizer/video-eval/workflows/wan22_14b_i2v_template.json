        "sampler_name": "euler",
        "scheduler": "simple",
        "start_at_step": 0,
        "end_at_step": 2,
        "return_with_leftover_noise": "enable",
        "model": ["104", 0],
        "positive": ["98", 0],
        "negative": ["98", 1],
        "latent_image": ["98", 2]
