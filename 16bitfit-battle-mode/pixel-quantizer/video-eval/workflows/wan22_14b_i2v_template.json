      "_meta": { "title": "KSampler Stage 1 (High Noise, Steps 0-2)" }
    },
    "85": {
      "class_type": "KSamplerAdvanced",
      "inputs": {
        "add_noise": "disable",
        "noise_seed": 0,
        "steps": 4,
        "cfg": 1.0,
        "sampler_name": "euler",
        "scheduler": "simple",
        "start_at_step": 2,
        "end_at_step": 4,
        "return_with_leftover_noise": "disable",
        "model": ["103", 0],
        "positive": ["98", 0],
        "negative": ["98", 1],
        "latent_image": ["86", 0]
